NEXT_PUBLIC_SUPABASE_URL="YOUR_SUPABASE_URL_HERE"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY_HERE"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE"
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# --- DEFAULT AUTH SEEDING ---
# These are used when hitting /api/auth/seed to bootstrap the initial admin hierarchy
ADMIN_EMAIL="owner@example.com"
SUPPORT_EMAIL="support@example.com"
PRO_EMAIL="pro@example.com"
FREE_EMAIL="free@example.com"
DEFAULT_PASSWORD="SecurePassword123!"

# --- EMAIL STACK ---
EMAIL_STRATEGY=smtp
EMAIL_FROM="Your App Name <your.email@example.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your.email@example.com"
SMTP_PASS="your_app_password_here"
