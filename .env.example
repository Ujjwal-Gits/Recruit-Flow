# ─────────────────────────────────────────────────────────────
# Recruit Flow — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Email — choose 'smtp' or 'resend'
EMAIL_STRATEGY=smtp
EMAIL_FROM="Recruit Flow <you@gmail.com>"

# SMTP (Gmail: use App Password, not your regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your_gmail_app_password

# Resend (alternative to SMTP — https://resend.com)
# RESEND_API_KEY=re_your_key_here

# Contact form — where contact page emails get sent
CONTACT_EMAIL=you@yourdomain.com

# Demo accounts for /api/auth/seed (optional, dev only)
ADMIN_EMAIL=owner@example.com
SUPPORT_EMAIL=support@example.com
PRO_EMAIL=pro@example.com
FREE_EMAIL=free@example.com
DEFAULT_PASSWORD=ChangeThisPassword123!
